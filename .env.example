# Credenciales de Alpaca (Paper: keys empiezan con PK)
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=

# Paper: https://paper-api.alpaca.markets | Live: https://api.alpaca.markets
# (sin /v2 al final)
APCA_API_BASE_URL=https://paper-api.alpaca.markets

# true = simula órdenes (seguro)
DRY_RUN=true

POLL_INTERVAL_SECONDS=60

# Acciones: AMD | Cripto: BTC/USD
SYMBOL=BTC/USD

# fixed | trailing
STRATEGY=trailing

# Si STRATEGY=fixed
# BUY_PRICE=64300
# SELL_PRICE=64350

# Si STRATEGY=trailing (porcentajes)
REBOUND_PCT=0.15
DROP_PCT=0.15
